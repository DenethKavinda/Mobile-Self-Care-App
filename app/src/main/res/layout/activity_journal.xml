<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/home_bg_gradient">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📓 My Journal"
            android:textSize="26sp"
            android:textColor="#2E3A59"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/entryEditText"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Write your journal entry here..."
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:gravity="top"
            android:layout_marginBottom="16dp"
            android:textColor="#2E3A59"/>

        <Button
            android:id="@+id/addButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Add Entry"
            android:background="@drawable/gradient_button_selector"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"/>

        <ListView
            android:id="@+id/entriesListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#CCCCCC"
            android:dividerHeight="1dp"/>
        <Button
            android:id="@+id/backHomeButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back to Home"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button_selector"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
