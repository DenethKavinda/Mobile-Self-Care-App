<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/peaceful_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/waterTrackerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 Water Tracker"
            android:textSize="26sp"
            android:textColor="#2E3A59"
            android:fontFamily="sans-serif-medium"/>

        <LinearLayout
            android:id="@+id/waterIconsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/completedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 8 liters completed"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:textColor="#2E3A59"/>

        <Button
            android:id="@+id/setGoalButton"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="Set Daily Goal"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button_selector"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/backHomeButton"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:text="⬅ Back Home"
            android:textColor="@android:color/white"
            android:background="@drawable/gradient_button_selector"
            android:layout_marginTop="24dp"/>
    </LinearLayout>
</ScrollView>
