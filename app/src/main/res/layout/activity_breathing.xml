<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/peaceful_gradient"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Breathing Exercises"
        android:textSize="26sp"
        android:textColor="#444444"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center" />

    <Spinner
        android:id="@+id/breathingModeSpinner"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_spinner_bg"
        android:padding="8dp"
        android:layout_marginBottom="20dp" />

    <ImageView
        android:id="@+id/breathingCircle"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_breathing_circle"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/breathingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to begin?"
        android:textSize="20sp"
        android:textColor="#555"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center" />

    <Button
        android:id="@+id/startBreathingButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Start Breathing"
        android:backgroundTint="#B0D9B1"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/backButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Back to Home"
        android:backgroundTint="#FFD6A5"
        android:textColor="#444"
        android:layout_marginBottom="30dp" />

    <TextView
        android:id="@+id/quoteText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#6B705C"
        android:textSize="16sp"
        android:layout_gravity="center"
        android:textStyle="italic" />

</LinearLayout>
