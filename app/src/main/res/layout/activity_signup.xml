<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/peaceful_bg"
    tools:context=".SignUpActivity">

    <ImageView
        android:id="@+id/signupLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="70dp"
        android:src="@drawable/ic_person"
        android:contentDescription="Signup Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/signupTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌟 Create Account"
        android:textSize="26sp"
        android:textColor="#2E3A59"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/signupLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <EditText
        android:id="@+id/usernameInput"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="👤 Username"
        android:background="@drawable/edittext_background"
        android:padding="16dp"
        android:inputType="textPersonName"
        app:layout_constraintTop_toBottomOf="@id/signupTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="40dp"/>

    <EditText
        android:id="@+id/signupEmail"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="📧 Email"
        android:background="@drawable/edittext_background"
        android:padding="16dp"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/usernameInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="40dp"/>

    <EditText
        android:id="@+id/signupPassword"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="🔒 Password"
        android:background="@drawable/edittext_background"
        android:padding="16dp"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/signupEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="40dp"/>

    <EditText
        android:id="@+id/signupContact"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="📞 Contact Number"
        android:background="@drawable/edittext_background"
        android:padding="16dp"
        android:inputType="phone"
        app:layout_constraintTop_toBottomOf="@id/signupPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="40dp"/>

    <Button
        android:id="@+id/signupButton"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:text="✨ Sign Up"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="@drawable/gradient_button_selector"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/signupContact"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/loginRedirect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔑 Already have an account? Log In"
        android:textColor="#2E3A59"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/signupButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
